{{!
@template core/filemanager_selectdirlayout

This template renders the window appearing to select a directory share.

Example context (json):
{}
}}
<div class="file-picker fp-select-dir">
    <div class="container">
        <form>
            <fieldset class="mb-3 row flex-column">
                <div class="form-check fp-linktype-4">
                    <label class="form-check-label">
                        <input class="form-check-input" type="radio">
                        {{#str}}makefolderreference, repository{{/str}}
                    </label>
                </div>
            </fieldset>
            <div class="fp-saveas mb-3 row">
                <label class="col-form-label">{{#str}}saveasfolder, repository{{/str}}</label>
                <input class="form-control" type="text">
            </div>
            <div class="mb-3 row">
                <div class="fp-select-buttons">
                    <button class="fp-select-confirm btn-primary btn">{{#str}}getfolder, repository{{/str}}</button>
                    <button class="fp-select-cancel btn-secondary btn">{{#str}}cancel{{/str}}</button>
                </div>
            </div>
        </form>
    </div>
</div>
